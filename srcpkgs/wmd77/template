do_build() {
	cargo build --release
}

do_install() {
	sed -i '3i conky -c ~/.conkyrc1 &' etc/xdg/wmd77/startup.sh
	vmkdir /usr/bin
	vmkdir /usr/share/xsessions
	vmkdir /etc/xdg/wmd77
	vcopy target/release/wmd77 /usr/bin/
	vcopy wmd77.desktop /usr/share/xsessions/
	vcopy etc/xdg/wmd77/'*' /etc/xdg/wmd77/
}
