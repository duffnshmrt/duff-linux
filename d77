#!/bin/bash

set -eu

. ./build/lib.sh

PROGNAME=$(basename "$0")
ARCH=$(uname -m)
IMAGES="plasma"
GPU_PROFILE="amd"
TRIPLET=
REPO=
REPO_PATHS=()
KERNEL_PACKAGES=()
CUSTOM_KERNEL_SELECTION=no
DATE=$(date -u +%Y%m%d)
BUILD_LOG="$(pwd)/d77-build.log"
WORKDIR_OWNER_UID=$(stat -c '%u' .)
WORKDIR_OWNER_GID=$(stat -c '%g' .)

usage() {
	cat <<-EOH
	Usage: $PROGNAME [options ...] [-- mklive options ...]

	Wrapper script around mklive.sh for several standard flavors of live images.
	Adds d77void-installer and other helpful utilities to the generated images.
        
	adaptation of mkiso.sh by Daniel Azevedo (dani-77) 

	OPTIONS
	 -a <arch>     Set architecture (or platform) in the image. Asahi is untested.
	 -b <variant>  Only "plasma" is supported here. (WIP)
               May be specified multiple times to build multiple variants.
	 -g <gpu>      Set GPU profile: amd (default) or nvidia
	 -k <kernel>   Set kernel package/version to build.
	               Accepts values like 6.19, 7.0, linux6.19, linux7.0.
	               May be specified multiple times to build multiple kernels.
	 -d <date>     Override the datestamp on the generated image (YYYYMMDD format)
	 -t <arch-date-variant>
	               Equivalent to setting -a, -b, and -d
	 -r <repo>     Use this XBPS repository. May be specified multiple times
	 -h            Show this help and exit
	 -V            Show version and exit

	Other options can be passed directly to mklive.sh by specifying them after the --.
	See mklive.sh -h for more details.
	EOH
}

default_kernel_pkg() {
    case "$1" in
        asahi*) printf '%s\n' "linux-asahi" ;;
        *) printf '%s\n' "linux7.0" ;;
    esac
}

normalize_kernel_pkg() {
    case "$1" in
        linux|linux-asahi|linux-lts|linux-mainline|linux[0-9]*)
            printf '%s\n' "$1"
            ;;
        [0-9]*)
            printf 'linux%s\n' "$1"
            ;;
        *)
            return 1
            ;;
    esac
}

validate_kernel_pkg_for_arch() {
    case "$ARCH:$1" in
        asahi*:linux-asahi|x86_64*:linux[0-9]*|i686*:linux[0-9]*|aarch64*:linux[0-9]*)
            ;;
        asahi*:*)
            echo "Kernel $1 is not supported on $ARCH; use linux-asahi" >&2
            return 1
            ;;
        *:linux-asahi)
            echo "Kernel $1 is only supported on asahi targets" >&2
            return 1
            ;;
        *)
            ;;
    esac
}

kernel_headers_pkg() {
    case "$1" in
        linux|linux-lts|linux-mainline|linux[0-9]*)
            printf '%s-headers\n' "$1"
            ;;
        *)
            return 1
            ;;
    esac
}

kernel_suffix() {
    case "$1" in
        linux[0-9]*) printf '%s\n' "${1#linux}" ;;
        linux-*) printf '%s\n' "${1#linux-}" ;;
        linux) printf '%s\n' "default" ;;
        *) printf '%s\n' "$1" ;;
    esac
}

while getopts "a:b:d:g:k:t:hr:V" opt; do
case $opt in
    a) ARCH="$OPTARG";;
    b) IMAGES="$OPTARG";;
    d) DATE="$OPTARG";;
    g) GPU_PROFILE="$OPTARG";;
    k)
        kernel_pkg=$(normalize_kernel_pkg "$OPTARG") || {
            echo "Unsupported kernel value: $OPTARG" >&2
            exit 1
        }
        KERNEL_PACKAGES+=("$kernel_pkg")
        CUSTOM_KERNEL_SELECTION=yes
        ;;
    r) REPO="-r $OPTARG $REPO"; REPO_PATHS+=("$OPTARG");;
    t) TRIPLET="$OPTARG";;
    V) version; exit 0;;
    h) usage; exit 0;;
    *) usage >&2; exit 1;;
esac
done
shift $((OPTIND - 1))

INCLUDEDIR=
SHIMDIR=
trap "cleanup" INT TERM EXIT

cleanup() {
    if [ -n "${INCLUDEDIR:-}" ]; then
        rm -rf "$INCLUDEDIR"
    fi

    if [ -n "${SHIMDIR:-}" ]; then
        rm -rf "$SHIMDIR"
    fi

    return 0
}

create_build_workdirs() {
    INCLUDEDIR=$(mktemp -d)
    SHIMDIR=$(mktemp -d)
}

restore_ownership() {
    for path in "$@"; do
        [ -e "$path" ] || continue
        chown "$WORKDIR_OWNER_UID:$WORKDIR_OWNER_GID" "$path" 2>/dev/null || true
    done
}

init_logging() {
    : > "$BUILD_LOG"
    exec > >(tee "$BUILD_LOG") 2>&1
    restore_ownership "$BUILD_LOG"
    printf 'Build log: %s\n' "$BUILD_LOG"
    printf 'Build started: %s\n' "$(date -u '+%Y-%m-%d %H:%M:%S UTC')"
}

setup_build_shims() {
    cat <<'EOF' > "$SHIMDIR/grub-mkconfig"
#!/bin/sh
printf 'd77: skipped grub-mkconfig during ISO build\n' >&2
exit 0
EOF
    chmod 755 "$SHIMDIR/grub-mkconfig"

    cat <<'EOF' > "$SHIMDIR/update-grub"
#!/bin/sh
exec grub-mkconfig "$@"
EOF
    chmod 755 "$SHIMDIR/update-grub"
}

include_installer() {
    if [ -x build/installer.sh ]; then
        MKLIVE_VERSION="$(PROGNAME='' version)"
        installer=$(mktemp)
        sed "s/@@MKLIVE_VERSION@@/${MKLIVE_VERSION}/" build/installer.sh > "$installer"
        install -Dm755 "$installer" "$INCLUDEDIR"/usr/bin/d77void-installer
        rm "$installer"
    else
        echo build/installer.sh not found >&2
        exit 1
    fi
}

setup_pipewire() {
    PKGS="$PKGS pipewire wireplumber alsa-pipewire"
    case "$ARCH" in
        asahi*)
            PKGS="$PKGS asahi-audio"
            SERVICES="$SERVICES speakersafetyd"
            ;;
    esac

    # Do not autostart PipeWire via XDG desktop autostart.
    # Starting it this way can make Plasma show the volume OSD shortly after login.
    # Let the session bring audio up normally instead.
    mkdir -p "$INCLUDEDIR"/etc/pipewire/pipewire.conf.d
    ln -sf /usr/share/examples/wireplumber/10-wireplumber.conf \
        "$INCLUDEDIR"/etc/pipewire/pipewire.conf.d/
    ln -sf /usr/share/examples/pipewire/20-pipewire-pulse.conf \
        "$INCLUDEDIR"/etc/pipewire/pipewire.conf.d/

    mkdir -p "$INCLUDEDIR"/etc/alsa/conf.d
    ln -sf /usr/share/alsa/alsa.conf.d/50-pipewire.conf \
        "$INCLUDEDIR"/etc/alsa/conf.d/
    ln -sf /usr/share/alsa/alsa.conf.d/99-pipewire-default.conf \
        "$INCLUDEDIR"/etc/alsa/conf.d/
}

include_common() {
	mkdir -p "$INCLUDEDIR"/etc
	mkdir -p "$INCLUDEDIR"/usr/share/polkit-1/rules.d
	cp -r ./build/common/calamares "$INCLUDEDIR"/etc/
	cp -r build/$variant/skel "$INCLUDEDIR"/etc/
	cp ./build/common/asound.conf "$INCLUDEDIR"/etc/
	cp ./build/common/50-udisks.rules "$INCLUDEDIR"/usr/share/polkit-1/rules.d/
}

include_plasma() {
    # Create essential directory structure
    mkdir -p "$INCLUDEDIR"/etc/skel/.config
    mkdir -p "$INCLUDEDIR"/etc/xdg/autostart
    mkdir -p "$INCLUDEDIR"/usr/share/polkit-1/rules.d

    # Create the XBPS hook directory
    mkdir -p "$INCLUDEDIR"/etc/xbps.d/hooks

    # Create a pre-transaction hook for snapshots
    cat <<'EOF' > "$INCLUDEDIR"/etc/xbps.d/hooks/pre-install-snapshot.sh
#!/bin/sh
if ! command -v snapper >/dev/null || ! command -v findmnt >/dev/null; then
    exit 0
fi

ROOT_FSTYPE=$(findmnt -n -o FSTYPE / 2>/dev/null)
ROOT_SUBVOL=$(findmnt -n -o OPTIONS / 2>/dev/null | tr ',' '\n' | sed -n 's/^subvol=//p' | head -n 1)

case "$ROOT_FSTYPE:$ROOT_SUBVOL" in
    btrfs:/@|btrfs:@) ;;
    *)
        exit 0
        ;;
esac

[ -d /.snapshots ] || exit 0

snapper -c root create --description "Before XBPS transaction" --cleanup-algorithm number
# Manually update GRUB since the daemon is missing
grub-mkconfig -o /boot/grub/grub.cfg
EOF
    chmod 755 "$INCLUDEDIR"/etc/xbps.d/hooks/pre-install-snapshot.sh

    # Overlay Flag Script
    mkdir -p "$INCLUDEDIR"/etc/runit/core-services
    cat <<'EOF' > "$INCLUDEDIR"/etc/runit/core-services/03-snapshot-overlay.sh
#!/bin/sh
# Duff-Linux: Snapshot Overlayfs Handler — fallback if auto-restore fails.
# Uses btrfs property check instead of [ -w / ] so overlayfs can't fool it.
if btrfs subvolume show / 2>/dev/null | grep -q 'Flags:.*readonly'; then
    mount -t tmpfs -o mode=1777,nosuid,nodev tmpfs /tmp
    OVERLAY_DIRS="/var/lib/sddm /var/lib/AccountsService /var/cache /var/log /var/tmp /home"
    for dir in $OVERLAY_DIRS; do
        if [ -d "$dir" ]; then
            mkdir -p "/run/overlay${dir}/upper" "/run/overlay${dir}/work"
            mount -t overlay overlay -o lowerdir="${dir}",upperdir="/run/overlay${dir}/upper",workdir="/run/overlay${dir}/work" "${dir}"
        fi
    done
fi
EOF
    chmod 755 "$INCLUDEDIR"/etc/runit/core-services/03-snapshot-overlay.sh

    # Auto-Restore Runit Service (runs before SDDM, no user interaction needed)
    cat <<'EOF' > "$INCLUDEDIR"/etc/runit/core-services/04-auto-restore.sh
#!/bin/sh
# Duff-Linux: Auto-restore snapshot chosen at GRUB boot.
# Called directly from /etc/sv/sddm/run before SDDM starts.
# Logs to /run/duff-restore.log for diagnostics.

LOG=/run/duff-restore.log
echo "$(date): duff-restore started" >> "$LOG"

SNAP_PATH=$(/usr/bin/btrfs subvolume show / 2>/dev/null | head -1 | tr -d '\t ')
echo "$(date): subvolume='$SNAP_PATH'" >> "$LOG"

case "$SNAP_PATH" in
    *snapshots/*/snapshot) ;;
    *)
        echo "$(date): normal boot, exiting" >> "$LOG"
        exit 0
        ;;
esac

ROOT_DEV=$(/usr/bin/findmnt -n -o SOURCE / | sed 's/\[.*//')
echo "$(date): device=$ROOT_DEV  restoring..." >> "$LOG"

mkdir -p /run/duff-mnt

if ! /usr/bin/mount -o subvolid=5 "$ROOT_DEV" /run/duff-mnt; then
    echo "$(date): ERROR: mount failed" >> "$LOG"; exit 1
fi

BACKUP="@_backup_$(date +%Y%m%d_%H%M%S)"

if ! mv /run/duff-mnt/@ "/run/duff-mnt/$BACKUP"; then
    echo "$(date): ERROR: rename @ failed" >> "$LOG"
    /usr/bin/umount /run/duff-mnt; exit 1
fi

if ! /usr/bin/btrfs subvolume snapshot "/run/duff-mnt/$SNAP_PATH" /run/duff-mnt/@; then
    echo "$(date): ERROR: snapshot failed, rolling back" >> "$LOG"
    mv "/run/duff-mnt/$BACKUP" /run/duff-mnt/@
    /usr/bin/umount /run/duff-mnt; exit 1
fi

rm -f /run/duff-mnt/@home/*/.cache/ksycoca* 2>/dev/null || true

/usr/bin/umount /run/duff-mnt
echo "$(date): restore complete, rebooting" >> "$LOG"
sleep 2
/sbin/reboot
EOF
    chmod 755 "$INCLUDEDIR"/etc/runit/core-services/04-auto-restore.sh

    # SDDM Run Script: call auto-restore before SDDM ever starts
    mkdir -p "$INCLUDEDIR"/etc/sv/sddm
    cat <<'EOF' > "$INCLUDEDIR"/etc/sv/sddm/run
#!/bin/sh
# Duff-Linux: on snapshot boot, restore and reboot before SDDM starts.
# On normal boot, falls through immediately to exec sddm.
/etc/runit/core-services/04-auto-restore.sh

# runit starts all services concurrently. Wait for elogind to register on
# D-Bus before starting SDDM; without this, SDDM's login1 query fails and
# all power-management buttons (Shutdown/Restart/Sleep/Hibernate) stay greyed.
i=0
while [ $i -lt 30 ]; do
    dbus-send --system --dest=org.freedesktop.login1 \
        --type=method_call / \
        org.freedesktop.DBus.Peer.Ping >/dev/null 2>&1 && break
    sleep 1
    i=$((i + 1))
done

[ -r ./conf ] && . ./conf
exec sddm
EOF
    chmod 755 "$INCLUDEDIR"/etc/sv/sddm/run

    # SDDM locale env — runit never reads /etc/locale.conf, so SDDM inherits
    # the C locale (HH:mm:ss). This conf file is sourced by the run script above.
    cat <<'EOF' > "$INCLUDEDIR"/etc/sv/sddm/conf
export LANG=en_US.UTF-8
export LC_TIME=en_US.UTF-8
EOF

    # Core Services Bootstrap
    cat <<'EOF' > "$INCLUDEDIR"/etc/runit/run-core-services.sh
#!/bin/sh
for f in /etc/runit/core-services/*.sh; do
    [ -x "$f" ] && . "$f"
done
EOF
    chmod 755 "$INCLUDEDIR"/etc/runit/run-core-services.sh

    # Autostart Calamares in the Live ISO
    mkdir -p "$INCLUDEDIR"/etc/skel/.config/autostart
    ln -sf /usr/share/applications/calamares.desktop "$INCLUDEDIR"/etc/skel/.config/autostart/calamares.desktop

    # Create the system-wide Flatpak remotes directory
    mkdir -p "$INCLUDEDIR"/etc/flatpak/remotes.d
    
    # Download the Flathub repo file directly into the ISO
    curl -L -o "$INCLUDEDIR"/etc/flatpak/remotes.d/flathub.flatpakrepo https://dl.flathub.org/repo/flathub.flatpakrepo

    # Create the SDDM configuration directory
    mkdir -p "$INCLUDEDIR"/etc/sddm.conf.d

    # Keep KDE's Breeze SDDM theme and ensure the installed user (UID 1000)
    # is always visible without AccountsService.
    cat <<EOF > "$INCLUDEDIR"/etc/sddm.conf.d/kde_theme.conf
[Theme]
Current=breeze

[Users]
MinimumUid=1000
MaximumUid=60000
RememberLastUser=true
EOF

    # Hide the Breeze SDDM hibernate button in the live image after the
    # auto-login Plasma session starts. The live user has passwordless sudo,
    # so this patches the real theme file without touching SDDM's boot path.
    mkdir -p "$INCLUDEDIR"/usr/local/bin
    cat <<'EOF' > "$INCLUDEDIR"/usr/local/bin/duff-hide-sddm-hibernate
#!/bin/sh
qml=/usr/share/sddm/themes/breeze/Main.qml
[ -f "$qml" ] || exit 0
perl -0pi -e 's/enabled: sddm\.canHibernate(?!\n\s*visible: false)/enabled: sddm.canHibernate\n                        visible: false/' "$qml"
EOF
    chmod 755 "$INCLUDEDIR"/usr/local/bin/duff-hide-sddm-hibernate

    cat <<'EOF' > "$INCLUDEDIR"/usr/local/bin/duff-hide-sddm-hibernate-live
#!/bin/sh
command -v sudo >/dev/null 2>&1 || exit 0
sudo /usr/local/bin/duff-hide-sddm-hibernate >/dev/null 2>&1 || true
EOF
    chmod 755 "$INCLUDEDIR"/usr/local/bin/duff-hide-sddm-hibernate-live

    cat <<'EOF' > "$INCLUDEDIR"/etc/xdg/autostart/duff-hide-sddm-hibernate.desktop
[Desktop Entry]
Type=Application
Name=Hide SDDM Hibernate Button
Exec=/usr/local/bin/duff-hide-sddm-hibernate-live
OnlyShowIn=KDE;
X-KDE-AutostartPhase=1
NoDisplay=true
EOF

    # Set LC_TIME so SDDM's login-screen clock uses 12-hour without seconds.
    # Without this the C locale produces HH:mm:ss (24-hour with seconds).
    mkdir -p "$INCLUDEDIR"/etc
    cat <<'EOF' > "$INCLUDEDIR"/etc/locale.conf
LC_TIME=en_US.UTF-8
EOF

    # Keep functional configurations for the installer and audio
    cp -r ./build/common/calamares "$INCLUDEDIR"/etc/
    cp ./build/common/asound.conf "$INCLUDEDIR"/etc/
    cp ./build/common/50-udisks.rules "$INCLUDEDIR"/usr/share/polkit-1/rules.d/

    # Seed a complete Breeze Dark Plasma profile for new users.
    # The lock screen inherits these Plasma defaults; storing the
    # look-and-feel package under [KDE] is required for Plasma to
    # recognize it consistently.
    cat <<'EOF' > "$INCLUDEDIR"/etc/skel/.config/kdeglobals
[General]
Name=Breeze Dark
shadeSortColumn=true
widgetStyle=Breeze

[KDE]
ColorScheme=BreezeDark
LookAndFeelPackage=org.kde.breezedark.desktop
contrast=4
EOF

    cat <<'EOF' > "$INCLUDEDIR"/etc/skel/.config/kcminputrc
[Mouse]
cursorTheme=breeze_cursors
EOF

    cat <<'EOF' > "$INCLUDEDIR"/etc/skel/.config/ksplashrc
[KSplash]
Theme=org.kde.breeze.desktop
EOF

    # Force KDE's own locale layer to use 12-hour time without seconds for
    # both the lock screen and the desktop clock.
    cat <<'EOF' > "$INCLUDEDIR"/etc/skel/.config/plasma-localerc
[Formats]
LC_TIME=en_US.UTF-8
EOF

    # Start OctoXBPS through a small Plasma Wayland wrapper. This removes the
    # old sleep-based workaround and instead restarts plasmashell after real
    # display-layout changes, which restores lost tray icons when the Plasma
    # system tray hits its monitor-change bug.
    mkdir -p "$INCLUDEDIR"/usr/local/bin
    cat <<'EOF' > "$INCLUDEDIR"/usr/local/bin/duff-plasma-tray-fix
#!/bin/sh

is_plasma_wayland() {
    [ "${XDG_SESSION_TYPE:-}" = "wayland" ] || return 1

    case "${XDG_CURRENT_DESKTOP:-}:${DESKTOP_SESSION:-}" in
        *KDE*:*|*PLASMA*:*|*:*plasma*|*:*kde*)
            return 0
            ;;
    esac

    [ -n "${KDE_FULL_SESSION:-}" ]
}

dbus_name_has_owner() {
    command -v dbus-send >/dev/null 2>&1 || return 1

    dbus-send --session --print-reply \
        --dest=org.freedesktop.DBus \
        /org/freedesktop/DBus \
        org.freedesktop.DBus.NameHasOwner \
        "string:$1" 2>/dev/null | grep -q "boolean true"
}

wait_for_plasma_tray() {
    count=0

    while [ "$count" -lt 60 ]; do
        if pgrep -x plasmashell >/dev/null 2>&1 && \
           dbus_name_has_owner org.kde.StatusNotifierWatcher; then
            return 0
        fi

        count=$((count + 1))
        sleep 1
    done

    return 0
}

log_file="${XDG_RUNTIME_DIR:-/tmp}/duff-plasma-tray-fix.log"
log_max_bytes=262144
log_keep_lines=200
startup_grace_seconds=8

trim_log_file() {
    [ -f "$log_file" ] || return 0

    log_size=$(wc -c < "$log_file" 2>/dev/null || printf '0')
    [ "${log_size:-0}" -le "$log_max_bytes" ] && return 0

    tmp_log="${log_file}.tmp"
    tail -n "$log_keep_lines" "$log_file" > "$tmp_log" 2>/dev/null || return 0
    mv "$tmp_log" "$log_file"
}

log_message() {
    trim_log_file
    printf '%s %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$*" >> "$log_file"
}

restart_state_dir="${XDG_RUNTIME_DIR:-/tmp}/duff-plasma-tray-fix"
pending_restart_pid_file="$restart_state_dir/pending-restart.pid"
last_restart_file="$restart_state_dir/last-restart"
last_display_state_file="$restart_state_dir/last-display-state"
startup_activity_file="$restart_state_dir/startup-activity"
startup_settled_file="$restart_state_dir/startup-settled"

ensure_restart_state_dir() {
    mkdir -p "$restart_state_dir"
}

get_last_restart_at() {
    if [ -r "$last_restart_file" ]; then
        cat "$last_restart_file"
    else
        printf '0\n'
    fi
}

get_display_state() {
    if command -v kscreen-doctor >/dev/null 2>&1; then
        kscreen-doctor -j 2>/dev/null | cksum | awk '{print $1 ":" $2}'
        return 0
    fi

    if command -v kscreen-console >/dev/null 2>&1; then
        kscreen-console outputs 2>/dev/null | cksum | awk '{print $1 ":" $2}'
        return 0
    fi

    return 1
}

get_last_display_state() {
    if [ -r "$last_display_state_file" ]; then
        cat "$last_display_state_file"
    else
        printf '\n'
    fi
}

set_last_display_state() {
    printf '%s\n' "$1" > "$last_display_state_file"
}

mark_startup_activity() {
    : > "$startup_activity_file"
}

startup_activity_seen() {
    [ -e "$startup_activity_file" ]
}

mark_startup_settled() {
    : > "$startup_settled_file"
}

startup_settled() {
    [ -e "$startup_settled_file" ]
}

clear_pending_restart() {
    rm -f "$pending_restart_pid_file"
}

schedule_plasmashell_restart() {
    ensure_restart_state_dir

    if [ -r "$pending_restart_pid_file" ]; then
        pending_pid=$(cat "$pending_restart_pid_file" 2>/dev/null || true)
        if [ -n "$pending_pid" ] && kill -0 "$pending_pid" 2>/dev/null; then
            kill "$pending_pid" 2>/dev/null || true
            log_message "rescheduling pending plasmashell restart"
        fi
        clear_pending_restart
    fi

    (
        trap 'clear_pending_restart' EXIT INT TERM HUP

        # KScreen emits display updates while outputs are still settling. A short
        # debounce lets nearby events coalesce into one restart.
        sleep 3
        restart_plasmashell
        date +%s > "$last_restart_file"
    ) >/dev/null 2>&1 &

    printf '%s\n' "$!" > "$pending_restart_pid_file"
}

handle_display_change_event() {
    now=$(date +%s)
    watcher_started_at=$2
    last_restart_at=$(get_last_restart_at)
    current_display_state=$(get_display_state || true)
    previous_display_state=$(get_last_display_state)
    watcher_age=$((now - watcher_started_at))

    if [ -n "$current_display_state" ] && [ "$current_display_state" = "$previous_display_state" ]; then
        if [ "$watcher_age" -lt "$startup_grace_seconds" ]; then
            mark_startup_activity
        fi
        log_message "display change event ignored because display state is unchanged"
        return 1
    fi

    if [ -n "$current_display_state" ]; then
        set_last_display_state "$current_display_state"
    fi

    # Plasma/KScreen often emit setup noise during login while outputs are
    # still coming online. Learn the settled layout during a short warm-up
    # window, then only react to real post-login layout changes.
    if [ "$watcher_age" -lt "$startup_grace_seconds" ]; then
        mark_startup_activity
        log_message "display change event ignored during startup stabilization"
        return 1
    fi

    # Some hardware emits one last real layout change shortly after the early
    # startup burst. If we already saw startup activity, absorb the first new
    # post-startup state as the settled baseline instead of restarting Plasma.
    if startup_activity_seen && ! startup_settled; then
        mark_startup_settled
        log_message "display change event absorbed as post-startup settled display state"
        return 1
    fi

    # Allow quick follow-up changes like Plasma's "Revert" action, but still
    # avoid restart storms if a fresh restart just happened moments ago.
    if [ $((now - last_restart_at)) -lt 4 ]; then
        log_message "display change event received but plasmashell restart is rate-limited"
        return 1
    fi

    log_message "display change event received; scheduling plasmashell restart"
    return 0
}

restart_plasmashell() {
    lockdir="${XDG_RUNTIME_DIR:-/tmp}/duff-plasmashell-restart.lock"

    mkdir "$lockdir" 2>/dev/null || return 0

    (
        trap 'rmdir "$lockdir"' EXIT INT TERM HUP

        # KScreen emits configChanged while outputs are still settling. A short
        # debounce avoids restarting plasmashell in the middle of the DRM/EGL
        # transition, which can make the restart fail.
        sleep 3

        if command -v systemctl >/dev/null 2>&1 && \
           systemctl --user --quiet is-active plasma-plasmashell.service >/dev/null 2>&1; then
            systemctl --user restart plasma-plasmashell.service >/dev/null 2>&1 && exit 0
        fi

        if command -v kquitapp6 >/dev/null 2>&1; then
            kquitapp6 plasmashell >/dev/null 2>&1 || true
        else
            pkill -x plasmashell >/dev/null 2>&1 || true
        fi

        sleep 1
        nohup plasmashell --replace >/dev/null 2>&1 &
    ) >/dev/null 2>&1 &
}

watch_display_changes() {
    notifier_pid=$1
    watcher_started_at=$(date +%s)
    ensure_restart_state_dir

    initial_display_state=$(get_display_state || true)
    if [ -n "$initial_display_state" ]; then
        set_last_display_state "$initial_display_state"
    else
        rm -f "$last_display_state_file"
    fi
    rm -f "$startup_activity_file" "$startup_settled_file"

    if command -v kscreen-console >/dev/null 2>&1; then
        kscreen-console monitor 2>/dev/null |
        while IFS= read -r line; do
            kill -0 "$notifier_pid" 2>/dev/null || break
            [ -n "$line" ] || continue

            handle_display_change_event "" "$watcher_started_at" || continue
            schedule_plasmashell_restart
        done
        return 0
    fi

    command -v dbus-monitor >/dev/null 2>&1 || {
        log_message "no KScreen monitor command available; skipping Plasma tray recovery watcher"
        return 0
    }

    dbus-monitor --session \
        "type='signal',sender='org.kde.KScreen',path='/backend',interface='org.kde.kscreen.Backend',member='configChanged'" 2>/dev/null |
    while IFS= read -r line; do
        kill -0 "$notifier_pid" 2>/dev/null || break

        case "$line" in
            signal*)
                handle_display_change_event "" "$watcher_started_at" || continue
                schedule_plasmashell_restart
                ;;
        esac
    done
}

run_notifier_session() {
    wait_for_plasma_tray
    existing_pids=$(pgrep -x octoxbps-notifier || true)

    if [ -n "$existing_pids" ]; then
        log_message "found pre-existing octoxbps-notifier instance(s): $existing_pids"
        pkill -x octoxbps-notifier 2>/dev/null || true
        sleep 2
    fi

    log_message "starting managed octoxbps-notifier instance"

    /usr/bin/octoxbps-notifier >> "$log_file" 2>&1 &
    notifier_pid=$!
    watcher_pid=

    if is_plasma_wayland; then
        watch_display_changes "$notifier_pid" &
        watcher_pid=$!
    fi

    wait "$notifier_pid"
    status=$?

    [ -n "$watcher_pid" ] && kill "$watcher_pid" 2>/dev/null || true
    clear_pending_restart

    log_message "managed octoxbps-notifier exited with status $status"
    return "$status"
}

