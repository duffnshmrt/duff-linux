ensure_nvidia_repo() {
    local repo=
    local main_repo=
    local nonfree_repo=

    [ "$GPU_PROFILE" = "nvidia" ] || return 0

    case "$ARCH" in
        x86_64*|i686*) ;;
        *) return 0 ;;
    esac

    for repo in "${REPO_PATHS[@]}"; do
        case "$repo" in
            */nonfree|*/nonfree/) return 0 ;;
        esac
    done

    for repo in "${REPO_PATHS[@]}"; do
        case "$repo" in
            */binpkgs|*/binpkgs/)
                main_repo="${repo%/}"
                nonfree_repo="${main_repo}/nonfree"
                if [ -d "$nonfree_repo" ]; then
                    REPO="-r $nonfree_repo $REPO"
                    REPO_PATHS+=("$nonfree_repo")
                    info_msg "d77: automatically adding NVIDIA nonfree repo: $nonfree_repo"
                    return 0
                fi
                ;;
        esac
    done

    cat >&2 <<EOF
NVIDIA build selected, but no XBPS nonfree repository was found.

The proprietary NVIDIA package is built into a separate nonfree repo in void-packages.
Build it first, then rerun d77 with both repositories:

  cd /home/\$USER/Documents/GitHub/void-packages
  echo XBPS_ALLOW_RESTRICTED=yes >> etc/conf
  ./xbps-src pkg nvidia
  sudo ./d77 -r /home/\$USER/Documents/GitHub/void-packages/hostdir/binpkgs/ -r /home/\$USER/Documents/GitHub/void-packages/hostdir/binpkgs/nonfree/ -g nvidia -b plasma --

EOF
    exit 1
}

ensure_nvidia_dkms_override() {
    local template=/home/duff/Documents/GitHub/duff-linux/build/srcpkgs/dkms/template
    local version=
    local revision=
    local repo=
    local main_repo=

    [ "$GPU_PROFILE" = "nvidia" ] || return 0

    if [ ! -f "$template" ]; then
        >&2 echo "Missing local dkms override template: $template"
        exit 1
    fi

    version=$(sed -n 's/^version=\(.*\)$/\1/p' "$template" | head -n1)
    revision=$(sed -n 's/^revision=\(.*\)$/\1/p' "$template" | head -n1)

    [ -n "$version" ] && [ -n "$revision" ] || {
        >&2 echo "Failed to determine expected dkms override version from $template"
        exit 1
    }

    for repo in "${REPO_PATHS[@]}"; do
        case "$repo" in
            */binpkgs|*/binpkgs/)
                main_repo="${repo%/}"
                if find "$main_repo" -maxdepth 1 -type f -name "dkms-${version}_${revision}*.xbps" | grep -q .; then
                    return 0
                fi
                cat >&2 <<EOF
NVIDIA build selected, but the local repo is still missing the required dkms override.

Expected local package:
  dkms-${version}_${revision}

The last build used the stock dkms package, which pulls in generic linux-headers
and causes the unwanted 6.12 DKMS build path.

Copy the updated dkms template into void-packages/srcpkgs, then rebuild it:

  cd /home/\$USER/Documents/GitHub/void-packages
  cp -r /home/\$USER/Documents/GitHub/duff-linux/build/srcpkgs/dkms srcpkgs/
  ./xbps-src pkg dkms

Then rerun the NVIDIA ISO build.
EOF
                exit 1
                ;;
        esac
    done
}

write_gpu_profile() {
    mkdir -p "$INCLUDEDIR"/etc/duff-linux
    printf '%s\n' "$GPU_PROFILE" > "$INCLUDEDIR"/etc/duff-linux/gpu-profile
}

build_variant() {
    variant="$1"
    selected_kernel_pkg="$2"
    shift
    shift

    cleanup
    create_build_workdirs
    setup_build_shims

    IMG=duff-linux-live-${ARCH}-${DATE}-${variant}-${GPU_PROFILE}.iso
    if [ "$CUSTOM_KERNEL_SELECTION" = yes ] || [ "${#KERNEL_PACKAGES[@]}" -gt 1 ]; then
        IMG=duff-linux-live-${ARCH}-${DATE}-${variant}-${GPU_PROFILE}-$(kernel_suffix "$selected_kernel_pkg").iso
    fi

    # el-cheapo installer is unsupported on arm because arm doesn't install a kernel by default
    # and to work around that would add too much complexity to it
    # thus everyone should just do a chroot install anyways
    WANT_INSTALLER=no
    case "$ARCH" in
        x86_64*|i686*)
            GRUB_PKGS="grub-i386-efi grub-x86_64-efi"
            case "$GPU_PROFILE" in
                amd)
                    GFX_PKGS="xorg-video-drivers"
                    GFX_WL_PKGS="mesa-dri"
                    GPU_DRIVER_PKGS=
                    ;;
                nvidia)
                    GFX_PKGS="xorg-video-drivers"
                    GFX_WL_PKGS="mesa-dri"
                    GPU_DRIVER_PKGS="nvidia"
                    ;;
                *)
                    >&2 echo "Unknown GPU profile $GPU_PROFILE"
                    exit 1
                    ;;
            esac
            WANT_INSTALLER=yes
            TARGET_ARCH="$ARCH"
	    D77_CORE="acpi alsa-plugins-pulseaudio alsa-utils bash-completion ca-certificates curl elogind fastfetch git inxi nano NetworkManager octoxbps polkit power-profiles-daemon sddm udiskie ufw unzip usbutils util-linux void-repo-multilib void-repo-multilib-nonfree void-repo-nonfree wget xdg-user-dirs xdg-user-dirs-gtk xdg-utils xinit zramen"
	    CALAMARES="calamares grub rsync"
	    COMMON=
	    PLASMA=
	    X11=
	    ;;
        aarch64*)
            GRUB_PKGS="grub-arm64-efi"
            GFX_PKGS="xorg-video-drivers"
            GFX_WL_PKGS="mesa-dri"
            GPU_DRIVER_PKGS=
            TARGET_ARCH="$ARCH"
            if [ "$GPU_PROFILE" != "amd" ]; then
                >&2 echo "GPU profile $GPU_PROFILE is not supported on $ARCH"
                exit 1
            fi
            ;;
        asahi*)
            GRUB_PKGS="asahi-base asahi-scripts grub-arm64-efi"
            GFX_PKGS="mesa-asahi-dri"
            GFX_WL_PKGS="mesa-asahi-dri"
            GPU_DRIVER_PKGS=
            TARGET_ARCH="aarch64${ARCH#asahi}"
            if [ "$GPU_PROFILE" != "amd" ]; then
                >&2 echo "GPU profile $GPU_PROFILE is not supported on $ARCH"
                exit 1
            fi
            ;;
    esac

    KERNEL_PKG="$selected_kernel_pkg"
    validate_kernel_pkg_for_arch "$KERNEL_PKG" || exit 1
    KERNEL_HEADERS_PKG=
    if KERNEL_HEADERS_PKG=$(kernel_headers_pkg "$KERNEL_PKG"); then
        :
    fi

    A11Y_PKGS="espeakup void-live-audio"
    PKGS="$KERNEL_HEADERS_PKG dialog cryptsetup lvm2 mdadm void-docs-browse xtools-minimal xmirror chrony tmux $A11Y_PKGS $GRUB_PKGS $GPU_DRIVER_PKGS"
    FONTS="font-misc-misc terminus-font dejavu-fonts-ttf"
    WAYLAND_PKGS="$GFX_WL_PKGS $FONTS"
    XORG_PKGS="$GFX_PKGS $FONTS xorg-minimal xorg-input-drivers setxkbmap xauth"
    SERVICES="sshd chronyd"

    case $variant in
        base)
            SERVICES="$SERVICES dhcpcd wpa_supplicant acpid"
        ;;     
	plasma)
	    PLASMA=yes
            PKGS="$PKGS $XORG_PKGS $WAYLAND_PKGS $D77_CORE $CALAMARES cronie ark kde-plasma kde-baseapps spectacle sddm-kcm sddm discover flatpak xdg-desktop-portal-kde kscreen"
            SERVICES="$SERVICES dbus elogind sddm NetworkManager polkitd power-profiles-daemon cronie zramen"
        ;;
        *)
            >&2 echo "Unknown variant $variant"
            exit 1
        ;;
    esac

    if [ "$COMMON" = yes ]; then
        include_common
    fi

    if [ "$PLASMA" = yes ]; then
        include_plasma
    fi

    if [ "$X11" = yes ]; then
        include_x11
    fi

    write_gpu_profile

    if [ "$WANT_INSTALLER" = yes ]; then
        include_installer
    else
        mkdir -p "$INCLUDEDIR"/usr/bin
        printf "#!/bin/sh\necho 'd77void-installer is not supported on this live image'\n" > "$INCLUDEDIR"/usr/bin/d77void-installer
        chmod 755 "$INCLUDEDIR"/usr/bin/d77void-installer
    fi

    if [ "$variant" != base ]; then
        setup_pipewire
    fi

    PATH="$SHIMDIR:$PATH" PRUNE_EXTRA_KERNELS=yes ./build/mklive.sh -a "$TARGET_ARCH" -o "$IMG" -p "$PKGS" -S "$SERVICES" -I "$INCLUDEDIR" \
        -T "duff-linux" \
        ${KERNEL_PKG:+-v $KERNEL_PKG} ${REPO} "$@"

	restore_ownership "$IMG" "$BUILD_LOG"
	cleanup
}

if [ ! -x build/mklive.sh ]; then
    echo build/mklive.sh not found >&2
    exit 1
fi

init_logging
ensure_nvidia_repo
ensure_nvidia_dkms_override

if [ -n "$TRIPLET" ]; then
    IFS=: read -r ARCH DATE VARIANT _ < <( echo "$TRIPLET" | sed -Ee 's/^(.+)-([0-9rc]+)-(.+)$/\1:\2:\3/' )
    if [ "${#KERNEL_PACKAGES[@]}" -eq 0 ]; then
        KERNEL_PACKAGES=("$(default_kernel_pkg "$ARCH")")
    fi
    for kernel_pkg in "${KERNEL_PACKAGES[@]}"; do
        build_variant "$VARIANT" "$kernel_pkg" "$@"
    done
else
    if [ "${#KERNEL_PACKAGES[@]}" -eq 0 ]; then
        KERNEL_PACKAGES=("$(default_kernel_pkg "$ARCH")")
    fi
    for image in $IMAGES; do
        for kernel_pkg in "${KERNEL_PACKAGES[@]}"; do
            build_variant "$image" "$kernel_pkg" "$@"
        done
    done
fi
