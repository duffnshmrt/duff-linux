#!/bin/bash

set -eu

. ./build/lib.sh

PROGNAME=$(basename "$0")
ARCH=$(uname -m)
IMAGES="plasma"
TRIPLET=
REPO=
DATE=$(date -u +%Y%m%d)
BUILD_LOG="$(pwd)/d77-build.log"
WORKDIR_OWNER_UID=$(stat -c '%u' .)
WORKDIR_OWNER_GID=$(stat -c '%g' .)

usage() {
	cat <<-EOH
	Usage: $PROGNAME [options ...] [-- mklive options ...]

	Wrapper script around mklive.sh for several standard flavors of live images.
	Adds d77void-installer and other helpful utilities to the generated images.
        
	adaptation of mkiso.sh by Daniel Azevedo (dani-77) 

	OPTIONS
	 -a <arch>     Set architecture (or platform) in the image. Asahi is untested.
	 -b <variant>  Only "plasma" is supported here. (WIP)
               May be specified multiple times to build multiple variants.
	 -d <date>     Override the datestamp on the generated image (YYYYMMDD format)
	 -t <arch-date-variant>
	               Equivalent to setting -a, -b, and -d
	 -r <repo>     Use this XBPS repository. May be specified multiple times
	 -h            Show this help and exit
	 -V            Show version and exit

	Other options can be passed directly to mklive.sh by specifying them after the --.
	See mklive.sh -h for more details.
	EOH
}

while getopts "a:b:d:t:hr:V" opt; do
case $opt in
    a) ARCH="$OPTARG";;
    b) IMAGES="$OPTARG";;
    d) DATE="$OPTARG";;
    r) REPO="-r $OPTARG $REPO";;
    t) TRIPLET="$OPTARG";;
    V) version; exit 0;;
    h) usage; exit 0;;
    *) usage >&2; exit 1;;
esac
done
shift $((OPTIND - 1))

INCLUDEDIR=$(mktemp -d)
SHIMDIR=$(mktemp -d)
trap "cleanup" INT TERM

cleanup() {
    rm -rf "$INCLUDEDIR"
    rm -rf "$SHIMDIR"
}

restore_ownership() {
    for path in "$@"; do
        [ -e "$path" ] || continue
        chown "$WORKDIR_OWNER_UID:$WORKDIR_OWNER_GID" "$path" 2>/dev/null || true
    done
}

init_logging() {
    : > "$BUILD_LOG"
    exec > >(tee "$BUILD_LOG") 2>&1
    restore_ownership "$BUILD_LOG"
    printf 'Build log: %s\n' "$BUILD_LOG"
    printf 'Build started: %s\n' "$(date -u '+%Y-%m-%d %H:%M:%S UTC')"
}

setup_build_shims() {
    cat <<'EOF' > "$SHIMDIR/grub-mkconfig"
#!/bin/sh
printf 'd77: skipped grub-mkconfig during ISO build\n' >&2
exit 0
EOF
    chmod 755 "$SHIMDIR/grub-mkconfig"

    cat <<'EOF' > "$SHIMDIR/update-grub"
#!/bin/sh
exec grub-mkconfig "$@"
EOF
    chmod 755 "$SHIMDIR/update-grub"
}

include_installer() {
    if [ -x build/installer.sh ]; then
        MKLIVE_VERSION="$(PROGNAME='' version)"
        installer=$(mktemp)
        sed "s/@@MKLIVE_VERSION@@/${MKLIVE_VERSION}/" build/installer.sh > "$installer"
        install -Dm755 "$installer" "$INCLUDEDIR"/usr/bin/d77void-installer
        rm "$installer"
    else
        echo build/installer.sh not found >&2
        exit 1
    fi
}

setup_pipewire() {
    PKGS="$PKGS pipewire alsa-pipewire"
    case "$ARCH" in
        asahi*)
            PKGS="$PKGS asahi-audio"
            SERVICES="$SERVICES speakersafetyd"
            ;;
    esac
    mkdir -p "$INCLUDEDIR"/etc/xdg/autostart
    ln -sf /usr/share/applications/pipewire.desktop "$INCLUDEDIR"/etc/xdg/autostart/
    mkdir -p "$INCLUDEDIR"/etc/pipewire/pipewire.conf.d
    ln -sf /usr/share/examples/wireplumber/10-wireplumber.conf "$INCLUDEDIR"/etc/pipewire/pipewire.conf.d/
    ln -sf /usr/share/examples/pipewire/20-pipewire-pulse.conf "$INCLUDEDIR"/etc/pipewire/pipewire.conf.d/
    mkdir -p "$INCLUDEDIR"/etc/alsa/conf.d
    ln -sf /usr/share/alsa/alsa.conf.d/50-pipewire.conf "$INCLUDEDIR"/etc/alsa/conf.d
    ln -sf /usr/share/alsa/alsa.conf.d/99-pipewire-default.conf "$INCLUDEDIR"/etc/alsa/conf.d
}

include_common() {
	mkdir -p "$INCLUDEDIR"/etc
	mkdir -p "$INCLUDEDIR"/usr/share/polkit-1/rules.d
	cp -r ./build/common/calamares "$INCLUDEDIR"/etc/
	cp -r build/$variant/skel "$INCLUDEDIR"/etc/
	cp ./build/common/asound.conf "$INCLUDEDIR"/etc/
	cp ./build/common/50-udisks.rules "$INCLUDEDIR"/usr/share/polkit-1/rules.d/
}

include_plasma() {
    # 1. Create essential directory structure
    mkdir -p "$INCLUDEDIR"/etc/skel/.config
    mkdir -p "$INCLUDEDIR"/etc/xdg/autostart
    mkdir -p "$INCLUDEDIR"/usr/share/polkit-1/rules.d

    # Create the XBPS hook directory
    mkdir -p "$INCLUDEDIR"/etc/xbps.d/hooks

# Create a pre-transaction hook for snapshots
    cat <<'EOF' > "$INCLUDEDIR"/etc/xbps.d/hooks/pre-install-snapshot.sh
#!/bin/sh
if ! command -v snapper >/dev/null || ! command -v findmnt >/dev/null; then
    exit 0
fi

ROOT_FSTYPE=$(findmnt -n -o FSTYPE / 2>/dev/null)
ROOT_SUBVOL=$(findmnt -n -o OPTIONS / 2>/dev/null | tr ',' '\n' | sed -n 's/^subvol=//p' | head -n 1)

case "$ROOT_FSTYPE:$ROOT_SUBVOL" in
    btrfs:/@|btrfs:@) ;;
    *)
        exit 0
        ;;
esac

[ -d /.snapshots ] || exit 0

snapper -c root create --description "Before XBPS transaction" --cleanup-algorithm number
# Manually update GRUB since the daemon is missing
grub-mkconfig -o /boot/grub/grub.cfg
EOF
    chmod 755 "$INCLUDEDIR"/etc/xbps.d/hooks/pre-install-snapshot.sh

# --- 1. The Overlay Flag Script ---
    mkdir -p "$INCLUDEDIR"/etc/runit/core-services
    cat <<'EOF' > "$INCLUDEDIR"/etc/runit/core-services/03-snapshot-overlay.sh
#!/bin/sh
# Duff-Linux: Snapshot Overlayfs Handler — fallback if auto-restore fails.
# Uses btrfs property check instead of [ -w / ] so overlayfs can't fool it.
if btrfs subvolume show / 2>/dev/null | grep -q 'Flags:.*readonly'; then
    mount -t tmpfs -o mode=1777,nosuid,nodev tmpfs /tmp
    OVERLAY_DIRS="/var/lib/sddm /var/lib/AccountsService /var/cache /var/log /var/tmp /home"
    for dir in $OVERLAY_DIRS; do
        if [ -d "$dir" ]; then
            mkdir -p "/run/overlay${dir}/upper" "/run/overlay${dir}/work"
            mount -t overlay overlay -o lowerdir="${dir}",upperdir="/run/overlay${dir}/upper",workdir="/run/overlay${dir}/work" "${dir}"
        fi
    done
fi
EOF
    chmod 755 "$INCLUDEDIR"/etc/runit/core-services/03-snapshot-overlay.sh

    # --- Auto-Restore Runit Service (runs before SDDM, no user interaction needed) ---
    cat <<'EOF' > "$INCLUDEDIR"/etc/runit/core-services/04-auto-restore.sh
#!/bin/sh
# Duff-Linux: Auto-restore snapshot chosen at GRUB boot.
# Called directly from /etc/sv/sddm/run before SDDM starts.
# Logs to /run/duff-restore.log for diagnostics.

LOG=/run/duff-restore.log
echo "$(date): duff-restore started" >> "$LOG"

SNAP_PATH=$(/usr/bin/btrfs subvolume show / 2>/dev/null | head -1 | tr -d '\t ')
echo "$(date): subvolume='$SNAP_PATH'" >> "$LOG"

case "$SNAP_PATH" in
    *snapshots/*/snapshot) ;;
    *)
        echo "$(date): normal boot, exiting" >> "$LOG"
        exit 0
        ;;
esac

ROOT_DEV=$(/usr/bin/findmnt -n -o SOURCE / | sed 's/\[.*//')
echo "$(date): device=$ROOT_DEV  restoring..." >> "$LOG"

mkdir -p /run/duff-mnt

if ! /usr/bin/mount -o subvolid=5 "$ROOT_DEV" /run/duff-mnt; then
    echo "$(date): ERROR: mount failed" >> "$LOG"; exit 1
fi

BACKUP="@_backup_$(date +%Y%m%d_%H%M%S)"

if ! mv /run/duff-mnt/@ "/run/duff-mnt/$BACKUP"; then
    echo "$(date): ERROR: rename @ failed" >> "$LOG"
    /usr/bin/umount /run/duff-mnt; exit 1
fi

if ! /usr/bin/btrfs subvolume snapshot "/run/duff-mnt/$SNAP_PATH" /run/duff-mnt/@; then
    echo "$(date): ERROR: snapshot failed, rolling back" >> "$LOG"
    mv "/run/duff-mnt/$BACKUP" /run/duff-mnt/@
    /usr/bin/umount /run/duff-mnt; exit 1
fi

rm -f /run/duff-mnt/@home/*/.cache/ksycoca* 2>/dev/null || true

/usr/bin/umount /run/duff-mnt
echo "$(date): restore complete, rebooting" >> "$LOG"
sleep 2
/sbin/reboot
EOF
    chmod 755 "$INCLUDEDIR"/etc/runit/core-services/04-auto-restore.sh

    # --- SDDM Run Script: call auto-restore before SDDM ever starts ---
    mkdir -p "$INCLUDEDIR"/etc/sv/sddm
    cat <<'EOF' > "$INCLUDEDIR"/etc/sv/sddm/run
#!/bin/sh
# Duff-Linux: on snapshot boot, restore and reboot before SDDM starts.
# On normal boot, falls through immediately to exec sddm.
/etc/runit/core-services/04-auto-restore.sh
[ -r ./conf ] && . ./conf
exec sddm
EOF
    chmod 755 "$INCLUDEDIR"/etc/sv/sddm/run

    # --- Core Services Bootstrap (sources the above scripts from stage 1) ---
    cat <<'EOF' > "$INCLUDEDIR"/etc/runit/run-core-services.sh
#!/bin/sh
for f in /etc/runit/core-services/*.sh; do
    [ -x "$f" ] && . "$f"
done
EOF
    chmod 755 "$INCLUDEDIR"/etc/runit/run-core-services.sh

    # 1. Autostart Calamares in the Live ISO
    mkdir -p "$INCLUDEDIR"/etc/skel/.config/autostart
    ln -sf /usr/share/applications/calamares.desktop "$INCLUDEDIR"/etc/skel/.config/autostart/calamares.desktop

    # 1. Create the system-wide Flatpak remotes directory
    mkdir -p "$INCLUDEDIR"/etc/flatpak/remotes.d
    
    # 2. Download the Flathub repo file directly into the ISO
    curl -L -o "$INCLUDEDIR"/etc/flatpak/remotes.d/flathub.flatpakrepo https://dl.flathub.org/repo/flathub.flatpakrepo

    # 1. Create the SDDM configuration directory
    mkdir -p "$INCLUDEDIR"/etc/sddm.conf.d

    # 2. Generate the config file to set the theme to Breeze
    cat <<EOF > "$INCLUDEDIR"/etc/sddm.conf.d/kde_theme.conf
[Theme]
Current=breeze
EOF

    # 2. Keep functional configurations for the installer and audio
    cp -r ./build/common/calamares "$INCLUDEDIR"/etc/
    cp ./build/common/asound.conf "$INCLUDEDIR"/etc/
    cp ./build/common/50-udisks.rules "$INCLUDEDIR"/usr/share/polkit-1/rules.d/

    # 3. Force Breeze Dark theme for the user profile
    cat <<EOF > "$INCLUDEDIR"/etc/skel/.config/kdeglobals
[General]
ColorScheme=BreezeDark
lookAndFeelPackage=org.kde.breezedark.desktop
EOF

    # 4. Set OctoXBPS Notifier to autostart by default
    ln -sf /usr/share/applications/octoxbps-notifier.desktop "$INCLUDEDIR"/etc/xdg/autostart/

    # 5. Duff Linux identity (live environment)
    cat <<'EOF' > "$INCLUDEDIR"/etc/os-release
NAME="Duff Linux"
ID=duff-linux
ID_LIKE=void
PRETTY_NAME="Duff Linux"
ANSI_COLOR="1;33"
HOME_URL="https://github.com/duffnshmrt/duff-linux"
SUPPORT_URL="https://github.com/duffnshmrt/duff-linux"
BUG_REPORT_URL="https://github.com/duffnshmrt/duff-linux/issues"
LOGO=duff-linux
EOF

    # 6. KDE "About this System" icon
    mkdir -p "$INCLUDEDIR"/usr/share/pixmaps
    mkdir -p "$INCLUDEDIR"/usr/share/icons/hicolor/256x256/apps
    cp ./build/common/calamares/branding/duff-linux/icon.png "$INCLUDEDIR"/usr/share/pixmaps/duff-linux.png
    cp ./build/common/calamares/branding/duff-linux/icon.png "$INCLUDEDIR"/usr/share/icons/hicolor/256x256/apps/duff-linux.png

    # 7. Fastfetch branding
    mkdir -p "$INCLUDEDIR"/etc/fastfetch
    cat <<'EOF' > "$INCLUDEDIR"/etc/fastfetch/duff-linux.txt
      .-.
     (, )O()
    ( )O.( ')o.
    |XXXXXXXX|O
  __|//\\//\\|o
 /.-|\\//\\//|
||  |//\\//\\|
 \'-|\\//\\//|
  `"|//\\//\\|
jgs |XXXXXXXX|
    `""`""`""`
EOF
    cat <<'EOF' > "$INCLUDEDIR"/etc/fastfetch/config.jsonc
{
    "logo": {
        "source": "/etc/fastfetch/duff-linux.txt",
        "type": "file",
        "color": { "1": "yellow" }
    },
    "modules": [
        "title",
        "separator",
        "os",
        "host",
        "kernel",
        "uptime",
        "packages",
        "shell",
        "display",
        "de",
        "wm",
        "theme",
        "icons",
        "font",
        "terminal",
        "cpu",
        "gpu",
        "memory",
        "swap",
        "disk",
        "battery",
        "locale",
        "break",
        "colors"
    ]
}
EOF

    # 8. Auto-run fastfetch when a terminal opens (login shells via profile.d)
    mkdir -p "$INCLUDEDIR"/etc/profile.d
    cat <<'EOF' > "$INCLUDEDIR"/etc/profile.d/fastfetch.sh
#!/bin/sh
[ -t 1 ] && fastfetch
EOF

    # 9. Skel .bashrc: proper defaults + fastfetch on terminal open
    cat <<'EOF' > "$INCLUDEDIR"/etc/skel/.bashrc
# ~/.bashrc
[[ $- != *i* ]] && return

PS1='\[\e[01;32m\]\u@\h\[\e[00m\]:\[\e[01;34m\]\w\[\e[00m\]\$ '

HISTCONTROL=ignoredups
HISTSIZE=1000
HISTFILESIZE=2000
shopt -s histappend checkwinsize

alias ls='ls --color=auto'
alias ll='ls -la'
alias grep='grep --color=auto'

[ -t 1 ] && fastfetch
EOF
}

include_x11() {
    	PKGS="$PKGS dunst redshift scrot slock st transset xautolock xcompmgr xterm"
	cp ./build/common/wswap-X "$INCLUDEDIR"/usr/bin/
}		

build_variant() {
    variant="$1"
    shift
    IMG=duff-linux-live-${ARCH}-${DATE}-${variant}.iso

    # el-cheapo installer is unsupported on arm because arm doesn't install a kernel by default
    # and to work around that would add too much complexity to it
    # thus everyone should just do a chroot install anyways
    WANT_INSTALLER=no
    case "$ARCH" in
        x86_64*|i686*)
            GRUB_PKGS="grub-i386-efi grub-x86_64-efi"
            GFX_PKGS="xorg-video-drivers"
            GFX_WL_PKGS="mesa-dri"
			KERNEL_PKG="linux7.0"
            WANT_INSTALLER=yes
            TARGET_ARCH="$ARCH"
	    D77_CORE="acpi alsa-plugins-pulseaudio alsa-utils bash-completion ca-certificates curl elogind fastfetch git inxi nano NetworkManager octoxbps polkit power-profiles-daemon sddm udiskie ufw unzip usbutils util-linux void-repo-multilib void-repo-multilib-nonfree void-repo-nonfree wget xdg-user-dirs xdg-user-dirs-gtk xdg-utils xinit xorg xorg-server zramen"
	    CALAMARES="calamares grub rsync"
	    COMMON=
	    PLASMA=
	    X11=
	    ;;
        aarch64*)
            GRUB_PKGS="grub-arm64-efi"
            GFX_PKGS="xorg-video-drivers"
            GFX_WL_PKGS="mesa-dri"
			KERNEL_PKG="linux7.0"
            TARGET_ARCH="$ARCH"
            ;;
        asahi*)
            GRUB_PKGS="asahi-base asahi-scripts grub-arm64-efi"
            GFX_PKGS="mesa-asahi-dri"
            GFX_WL_PKGS="mesa-asahi-dri"
            KERNEL_PKG="linux-asahi"
            TARGET_ARCH="aarch64${ARCH#asahi}"
            ;;
    esac

    A11Y_PKGS="espeakup void-live-audio"
    PKGS="linux7.0-headers dialog cryptsetup lvm2 mdadm void-docs-browse xtools-minimal xmirror chrony tmux $A11Y_PKGS $GRUB_PKGS"
    FONTS="font-misc-misc terminus-font dejavu-fonts-ttf"
    WAYLAND_PKGS="$GFX_WL_PKGS $FONTS"
    XORG_PKGS="$GFX_PKGS $FONTS xorg-minimal xorg-input-drivers setxkbmap xauth"
    SERVICES="sshd chronyd"

    case $variant in
        base)
            SERVICES="$SERVICES dhcpcd wpa_supplicant acpid"
        ;;     
	plasma)
	    PLASMA=yes
            PKGS="$PKGS $XORG_PKGS $WAYLAND_PKGS $D77_CORE $CALAMARES cronie ark kde-plasma kde-baseapps sddm-kcm sddm discover flatpak xdg-desktop-portal-kde"
            SERVICES="$SERVICES dbus sddm NetworkManager polkitd power-profiles-daemon cronie zramen"
        ;;
        *)
            >&2 echo "Unknown variant $variant"
            exit 1
        ;;
    esac

    if [ "$COMMON" = yes ]; then
        include_common
    fi

    if [ "$PLASMA" = yes ]; then
        include_plasma
    fi

    if [ "$X11" = yes ]; then
        include_x11
    fi

    if [ "$WANT_INSTALLER" = yes ]; then
        include_installer
    else
        mkdir -p "$INCLUDEDIR"/usr/bin
        printf "#!/bin/sh\necho 'd77void-installer is not supported on this live image'\n" > "$INCLUDEDIR"/usr/bin/d77void-installer
        chmod 755 "$INCLUDEDIR"/usr/bin/d77void-installer
    fi

    if [ "$variant" != base ]; then
        setup_pipewire
    fi

    PATH="$SHIMDIR:$PATH" ./build/mklive.sh -a "$TARGET_ARCH" -o "$IMG" -p "$PKGS" -S "$SERVICES" -I "$INCLUDEDIR" \
        -T "duff-linux" \
        ${KERNEL_PKG:+-v $KERNEL_PKG} ${REPO} "$@"

	restore_ownership "$IMG" "$BUILD_LOG"
	cleanup
}

if [ ! -x build/mklive.sh ]; then
    echo build/mklive.sh not found >&2
    exit 1
fi

init_logging
setup_build_shims

if [ -n "$TRIPLET" ]; then
    IFS=: read -r ARCH DATE VARIANT _ < <( echo "$TRIPLET" | sed -Ee 's/^(.+)-([0-9rc]+)-(.+)$/\1:\2:\3/' )
    build_variant "$VARIANT" "$@"
else
    for image in $IMAGES; do
        build_variant "$image" "$@"
    done
fi
